# ================= 数据库配置 =================
# 格式：mysql://用户名:密码@地址:端口/数据库名?字符集
DB_URL=mysql://root:your_password@localhost:3306/mydatabase?charset=utf8mb4

# ================= JWT 配置 =================
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ================= MinIO 配置 =================
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=video-analysis
MINIO_SECURE=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ================= 视频分析 Webhook =================
ANALYSIS_WEBHOOK_URL=http://localhost:8000/api/video/notifications
MINIO_NOTIFICATION_QUEUE=video-analysis-events
